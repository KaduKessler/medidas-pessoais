# Banco de dados
POSTGRES_DB=medidas_pessoais
POSTGRES_USER=medidas_user
POSTGRES_PASSWORD=troque-por-senha-forte
DATABASE_URL=postgresql://medidas_user:troque-por-senha-forte@postgres:5432/medidas_pessoais?schema=public

# JWT
JWT_SECRET=troque-por-secret-longo-e-aleatorio
JWT_EXPIRES_IN=7d

# App
NODE_ENV=production
FRONTEND_URL=https://medidas.kadukessler.com
API_URL=https://api-medidas.kadukessler.com

# Portas expostas no host (ajuste conforme disponibilidade no servidor)
BACKEND_PORT=3000
FRONTEND_PORT=80

# Tag da imagem (gerenciado pelo CI/CD)
IMAGE_TAG=latest
